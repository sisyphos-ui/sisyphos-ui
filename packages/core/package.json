{
  "name": "@sisyphos-ui/core",
  "version": "0.2.0",
  "description": "Core design system package with theme system and design tokens",
  "keywords": [
    "css-variables",
    "design-system",
    "react",
    "scss",
    "sisyphos-ui",
    "theme",
    "tokens",
    "typescript",
    "ui"
  ],
  "homepage": "https://github.com/sisyphos-ui/sisyphos-ui#readme",
  "bugs": {
    "url": "https://github.com/sisyphos-ui/sisyphos-ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sisyphos-ui/sisyphos-ui.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "author": "Sisyphos UI Contributors",
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal/index.d.ts",
      "import": "./dist/internal/index.mjs",
      "require": "./dist/internal/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./styles": {
      "sass": "./src/styles.scss",
      "default": "./dist/styles.css"
    },
    "./styles.scss": "./src/styles.scss",
    "./theme.css": "./dist/theme/default-theme.css",
    "./theme": {
      "sass": "./src/theme/default-theme.scss",
      "default": "./dist/theme/default-theme.css"
    },
    "./tokens": "./src/tokens/_index.scss",
    "./tokens/*": "./src/tokens/*.scss",
    "./tokens/variables": "./src/tokens/variables.scss",
    "./tokens/colors": "./src/tokens/colors.scss",
    "./tokens/mixins": "./src/tokens/mixins.scss",
    "./src/tokens/variables": "./src/tokens/variables.scss",
    "./src/tokens/variables.scss": "./src/tokens/variables.scss",
    "./src/tokens/mixins": "./src/tokens/mixins.scss",
    "./src/tokens/mixins.scss": "./src/tokens/mixins.scss",
    "./src/tokens/colors": "./src/tokens/colors.scss",
    "./src/tokens/colors.scss": "./src/tokens/colors.scss"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "dist",
    "src/**/*.scss"
  ],
  "scripts": {
    "build": "tsup && node scripts/build-css.mjs",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sisyphos-ui/eslint-config": "workspace:*",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "react": "^18.2.0",
    "sass": "^1.77.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
